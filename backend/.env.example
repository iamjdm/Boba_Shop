# Copy this file to .env and fill in your values.
# Never commit .env — only .env.example belongs in git.

# --- PostgreSQL ---
# Local dev: postgresql://postgres:yourpassword@localhost/boba_shop_db
# Render:    automatically set when you add a PostgreSQL database in the dashboard
DATABASE_URL=postgresql://postgres:@localhost/boba_shop_db

# --- Groq AI ---
# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# --- Flask ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_random_secret

# Set to "true" only during local development, never in production
FLASK_DEBUG=false

# --- CORS ---
# Comma-separated list of allowed origins — app will refuse to start if blank
# e.g. https://yourdomain.com or http://localhost:5500 for local dev
CORS_ORIGINS=http://localhost:5500

# --- Admin API Key ---
# Protects /applications and /submit-event from public access
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Send as header:  X-Admin-Key: <value>
ADMIN_KEY=change_me_to_a_random_secret
